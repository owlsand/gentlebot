# ============================================================================
# Gentlebot Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# All settings are validated on startup by gentlebot.config.settings

# ─── Environment ────────────────────────────────────────────────────────────
# Set to TEST for test server, PROD for production (default: PROD)
env=PROD

# ─── Discord Configuration (REQUIRED) ──────────────────────────────────────
# Your Discord bot token (REQUIRED)
DISCORD_TOKEN=your-token-here

# Optional Discord overrides
DISCORD_APPLICATION_ID=your-app-id
DISCORD_GUILD_ID=your-guild-id

# ─── Database Configuration (REQUIRED) ─────────────────────────────────────
# Option 1: Provide full DSN
PG_DSN=postgresql+asyncpg://gentlebot:your-db-password@db:5432/gentlebot

# Option 2: Or provide individual credentials
# PG_HOST=db
# PG_PORT=5432
# PG_USER=gentlebot
# PG_PASSWORD=your-db-password
# PG_DB=gentlebot

# Option 3: Or use DATABASE_URL (common for hosted providers)
# DATABASE_URL=

# ─── LLM API Keys ───────────────────────────────────────────────────────────
# Gemini API key for LLM features
GEMINI_API_KEY=your-gemini-api-key

# ─── External API Keys (Optional) ───────────────────────────────────────────
# Financial data
ALPHA_VANTAGE_KEY=your-alpha-vantage-key

# Yahoo Fantasy Sports
YAHOO_CLIENT_ID=your-yahoo-client-id
YAHOO_CLIENT_SECRET=your-yahoo-client-secret
YAHOO_REFRESH_TOKEN=your-yahoo-refresh-token
YAHOO_LEAGUE_KEY=your-yahoo-league-key

# ─── Channel ID Overrides (Optional) ────────────────────────────────────────
# Override specific channel IDs (defaults in bot_config.py)
MARKET_CHANNEL_ID=
SPORTS_CHANNEL_ID=
FANTASY_CHANNEL_ID=
MONEY_TALK_CHANNEL=
LOBBY_CHANNEL_ID=

# ─── Role ID Overrides (Optional) ───────────────────────────────────────────
# Override role IDs for engagement badges
ROLE_TOP_POSTER=
ROLE_CERTIFIED_BANGER=
ROLE_TOP_CURATOR=
ROLE_EARLY_BIRD=
ROLE_SUMMONER=
ROLE_LORE_CREATOR=
ROLE_REACTION_ENGINEER=
ROLE_GALAXY_BRAIN=
ROLE_WORDSMITH=
ROLE_SNIPER=
ROLE_NIGHT_OWL=
ROLE_COMEBACK_KID=
ROLE_GHOSTBUSTER=
ROLE_DAILY_HERO=

# Override role IDs for inactivity flags
ROLE_SHADOW_FLAG=
ROLE_LURKER_FLAG=
ROLE_NPC_FLAG=

# ─── Feature Flags ──────────────────────────────────────────────────────────
# Number of days to consider a user inactive (default: 14)
INACTIVE_DAYS=14

# Enable daily prompt feature (default: false)
DAILY_PROMPT_ENABLED=false

# ─── Infrastructure Settings ────────────────────────────────────────────────
# Enable pruning of old Docker images when the container starts
DOCKER_PRUNE=1

# Skip Postgres wait-loop and migrations (useful for CI)
SKIP_DB=0

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
